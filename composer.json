{
    "name": "psc-acme/tracker-product",
    "description": "Package tracker-product for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\TrackerProduct\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "monolog/monolog": "^3.2.0",
        "psr/http-message": "^2.0",
        "symfony/finder": "^7.0",
        "guzzlehttp/psr7": "^2.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "symfony/phpunit-bridge": "^7.0"
    },
    "minimum-stability": "dev",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}